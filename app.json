{
  "expo": {
    "name": "طبيبي - Tabibi",
    "slug": "tabibi",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tabibi",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F766E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tabibi.health"
    },
    "android": {
      "package": "com.tabibi.health",
      "versionCode": 7,
      "adaptiveIcon": {
        "backgroundColor": "#0F766E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://tabibi.health"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 35,
            "compileSdkVersion": 35
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Tabibi needs camera access for heart rate measurement and medication scanning.",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Tabibi needs your location to find nearby pharmacies, clinics, and hospitals.",
          "locationAlwaysPermission": "Tabibi needs your location to find nearby pharmacies, clinics, and hospitals.",
          "locationWhenInUsePermission": "Tabibi needs your location to find nearby pharmacies, clinics, and hospitals."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Tabibi needs camera access to scan medication labels.",
          "photosPermission": "Tabibi needs photo library access to select medication images."
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://tabibi.health"
      },
      "eas": {
        "projectId": "55040e0b-b828-4e2d-ad1a-06f151d02b3e"
      }
    }
  }
}